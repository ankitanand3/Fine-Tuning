  {
   "cell_type": "markdown",
   "id": "4f3d7d03",
   "metadata": {},
   "source": [
    "### Student Model (1 hidden layer)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "3d5c3099",
   "metadata": {},
   "outputs": [],
   "source": [
    "class StudentMLP(nn.Module):\n",
    "    def __init__(self, hidden=128):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(28*28, hidden),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(hidden, 10)\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.net(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "db482051",
   "metadata": {},
   "outputs": [],
   "source": [
    "student = StudentMLP(hidden=128)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "0b05ba65",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "StudentMLP(\n",
       "  (net): Sequential(\n",
       "    (0): Flatten(start_dim=1, end_dim=-1)\n",
       "    (1): Linear(in_features=784, out_features=128, bias=True)\n",
       "    (2): ReLU()\n",
       "    (3): Linear(in_features=128, out_features=10, bias=True)\n",
       "  )\n",
       ")"
      ]
     },
     "execution_count": 15,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "student"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "09869dd9",
   "metadata": {},
   "source": [
    "### Distillation training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "4ec9a79a",
   "metadata": {},
   "outputs": [],
   "source": [
    "temperature = 2.0\n",
    "alpha = 0.7\n",
    "ce_loss = nn.CrossEntropyLoss()\n",
    "kl_loss = nn.KLDivLoss(reduction='batchmean')\n",
    "optimizer = optim.Adam(student.parameters(), lr=1e-3)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0da75e25",
   "metadata": {},
   "source": [
    "### Process for distillation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "7e7ea37e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Training loop ---\n",
    "def distill(student, teacher, loader, epochs=1):\n",
    "    for ep in range(epochs):\n",
    "        student.train()\n",
    "        total_loss = 0\n",
    "        for x, y in loader:\n",
    "            # Teacher outputs (frozen — no training)\n",
    "            with torch.no_grad():\n",
    "                t_logits = teacher(x)\n",
    "                t_probs = torch.softmax(t_logits / temperature, dim=1)\n",
    "\n",
    "            # Student outputs\n",
    "            s_logits = student(x)\n",
    "            s_log_probs = torch.log_softmax(s_logits / temperature, dim=1)\n",
    "\n",
    "            # Losses\n",
    "            loss_soft = kl_loss(s_log_probs, t_probs) * (temperature**2)\n",
    "            loss_hard = ce_loss(s_logits, y)\n",
    "            loss = alpha * loss_soft + (1 - alpha) * loss_hard\n",
    "\n",
    "            optimizer.zero_grad()\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            total_loss += loss.item()\n",
    "        print(f\"Student Epoch {ep+1}: Loss = {total_loss/len(loader):.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "1f548062",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Student Epoch 1: Loss = 0.5135\n"
     ]
    }
   ],
   "source": [
    "distill(student, teacher, train_loader)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bdadbabb",
   "metadata": {},
   "source": [
    "### Evaluation Function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "9acbfc38",
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate(model, loader, name=\"Model\"):\n",
    "    model.eval()\n",
    "    correct, total = 0,0\n",
    "    with torch.no_grad():\n",
    "        for x, y in loader:\n",
    "            out = model(x)\n",
    "            preds = out.argmax(dim=1)\n",
    "            correct += (preds == y).sum().item()\n",
    "            total += y.size(0)\n",
    "    acc = correct / total * 100\n",
    "    print(f\"{name} Accuracy: {acc:.2f}%\")\n",
    "    return acc"
   ]
  },
